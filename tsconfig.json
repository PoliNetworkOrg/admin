{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["DOM", "DOM.Iterable", "ES2023"],
    "skipLibCheck": true,
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "moduleDetection": "force",
    "jsx": "react-jsx",
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noUncheckedSideEffectImports": true,
    "baseUrl": ".",
    "ignoreDeprecations": "6.0",
    "types": ["vite/client"],
    "paths": { "@/*": ["./src/*"] }
  },
  "include": [
    "src/routes/**/*",
    "src/components/app-mark.tsx",
    "src/components/dashboard-frame.tsx",
    "src/components/data-toolbar.tsx",
    "src/components/empty-state.tsx",
    "src/components/live-status.tsx",
    "src/components/pagination.tsx",
    "src/lib/auth.ts",
    "src/server/api.functions.ts",
    "src/router.tsx",
    "src/routeTree.gen.ts",
    "src/vite-env.d.ts",
    "vite.config.ts"
  ]
}
